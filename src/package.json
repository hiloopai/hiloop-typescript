{
  "name": "@hiloopai/sdk",
  "version": "0.4.0",
  "description": "Official TypeScript client for the hiloop API. Generated from the hiloop OpenAPI contract.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup index.ts --format esm,cjs --dts --clean --treeshake --tsconfig tsconfig.json"
  },
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hiloopai/hiloop-typescript.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": false
  }
}
